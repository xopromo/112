comm_rate  = input.float(0.100, "Комиссия %", step=0.01, group=grp_strat)
use_spread = input.bool(false, "Учитывать спред", group=grp_strat)
spread_pct = input.float(0.000, "Спред %", step=0.05, group=grp_strat)
atr_len    = input.int(17, "Период ATR", group=grp_strat)
atr_step   = input.int(2, "Шаг вариаций ATR", group=grp_strat)
max_bars   = input.int(8648, "Глубина теста", minval=100, maxval=500000, group=grp_strat)

grp_vis = "🎨 ВИЗУАЛИЗАЦИЯ"
show_tr   = input.bool(true, "Разметка сделок", group=grp_vis)
show_eq   = input.bool(true, "Equity", group=grp_vis)
eq_color  = input.color(color.new(color.yellow,20), "Цвет Equity", group=grp_vis)
eq_width  = input.int(2, "Толщина Equity", minval=1, maxval=4, group=grp_vis)
lbl_off_m = input.float(0.4, "Отступ ярлыков", step=0.1, group=grp_vis)
lbl_size  = input.string(size.small, "Размер текста", options=[size.tiny,size.small,size.normal,size.large], group=grp_vis)
c_win     = input.color(color.new(color.green,85), "Win", group=grp_vis)
c_loss    = input.color(color.new(color.red,85), "Loss", group=grp_vis)
c_neu     = input.color(color.new(color.gray,90), "Active", group=grp_vis)
c_tp_line = input.color(color.lime, "TP линия", group=grp_vis)
c_sl_line = input.color(color.red,  "SL линия", group=grp_vis)

grp_tab = "📊 ТАБЛИЦА"
pos_main  = input.string(position.top_right, "Позиция", group=grp_tab)
table_sz  = input.string(size.small, "Размер", options=[size.tiny,size.small,size.normal], group=grp_tab)
c_bg      = input.color(color.new(color.black,40), "Фон", group=grp_tab)

grp_bot = "🤖 БОТ-АЛЕРТЫ"
bot_fmt = input.string("text", "Формат сообщений", options=["text", "json"], tooltip="text — читаемый формат. json — для ботов (3Commas, Alertatron, Cornix и др.)", group=grp_bot)
bot_ticker_ov = input.string("", "Тикер (оставь пустым = авто)", tooltip="Если пусто — используется syminfo.ticker. Задай явно если бот требует конкретный символ, напр. BTCUSDT.", group=grp_bot)

// ==========================================
// 2. ИНДИКАТОРЫ И ФИЛЬТРЫ
// ==========================================
float atr_v  = ta.atr(atr_len)
float atr_m1 = ta.atr(math.max(1, atr_len - atr_step))
float atr_p1 = ta.atr(atr_len + atr_step)
float total_cost = comm_rate * 2 + (use_spread ? spread_pct : 0)
float entry_price = close

// Helper: convert seconds to TF string
f_tf_str(int secs) =>
	secs < 60 ? str.tostring(secs) + "S" : secs < 86400 ? str.tostring(math.round(secs / 60)) : str.tostring(math.round(secs / 86400)) + "D"

// ADX (Wilder's)
dirmov(len) =>
	up = ta.change(high)
	dn = -ta.change(low)
	pDM = na(up) ? na : (up > dn and up > 0 ? up : 0)
	mDM = na(dn) ? na : (dn > up and dn > 0 ? dn : 0)
	tr2 = ta.rma(ta.tr, len)
	[100 * ta.rma(pDM, len) / tr2, 100 * ta.rma(mDM, len) / tr2]

adx_calc(len) =>
	[pd, md] = dirmov(len)
	s = pd + md
	100 * ta.rma(math.abs(pd - md) / (s == 0 ? 1 : s), len)

string _adx_tf_str = adx_htf_ratio <= 1 ? timeframe.period : f_tf_str(timeframe.in_seconds() * adx_htf_ratio)
float adx_val = request.security(syminfo.tickerid, _adx_tf_str, adx_calc(adx_len), barmerge.gaps_off, barmerge.lookahead_on)
float adx_val_prev = request.security(syminfo.tickerid, _adx_tf_str, adx_calc(adx_len), barmerge.gaps_off, barmerge.lookahead_on)[adx_slope_bars]
bool adx_thresh_ok = use_adx ? (not na(adx_val) and adx_val >= adx_thresh) : true
bool adx_slope_ok  = not use_adx or not adx_slope or (not na(adx_val) and not na(adx_val_prev) and adx_val > adx_val_prev)
bool adx_ok        = adx_thresh_ok and adx_slope_ok

// Volatility filter
float atr_avg = ta.sma(atr_v, vol_f_len)
bool vol_f_ok   = use_vol_f   ? (atr_v[1] <= atr_avg[1] * vol_f_mult)  : true
bool atr_exp_ok = use_atr_exp ? (atr_v[1] >= atr_avg[1] * atr_exp_mult) : true

// Candle size filter
float candle_size_1 = high[1] - low[1]
bool candle_f_ok = not use_candle_f or (candle_size_1 >= candle_min * atr_v[1] and (candle_max <= 0 or candle_size_1 <= candle_max * atr_v[1]))

// Market structure
struct_pv_hi_v = ta.pivothigh(high, struct_pv_l, struct_pv_r)
struct_pv_lo_v = ta.pivotlow(low,  struct_pv_l, struct_pv_r)
var float struct_hi1 = na
var float struct_hi2 = na
var float struct_lo1 = na
var float struct_lo2 = na
var int struct_hi1_bar = na
var int struct_hi2_bar = na
var int struct_lo1_bar = na
var int struct_lo2_bar = na
if not na(struct_pv_hi_v)
	struct_hi2 := struct_hi1
	struct_hi2_bar := struct_hi1_bar
	struct_hi1 := high[struct_pv_r]
	struct_hi1_bar := bar_index - struct_pv_r
if not na(struct_pv_lo_v)
	struct_lo2 := struct_lo1
	struct_lo2_bar := struct_lo1_bar
	struct_lo1 := low[struct_pv_r]
	struct_lo1_bar := bar_index - struct_pv_r
bool struct_has_2hi = not na(struct_hi2) and not na(struct_hi2_bar) and (bar_index - struct_hi2_bar) <= struct_len_v
bool struct_has_2lo = not na(struct_lo2) and not na(struct_lo2_bar) and (bar_index - struct_lo2_bar) <= struct_len_v
bool struct_bull = struct_has_2hi and struct_has_2lo and struct_hi1 > struct_hi2 and struct_lo1 > struct_lo2
bool struct_bear = struct_has_2hi and struct_has_2lo and struct_hi1 < struct_hi2 and struct_lo1 < struct_lo2
bool struct_ok_l = not use_struct or struct_bull
bool struct_ok_s = not use_struct or struct_bear

