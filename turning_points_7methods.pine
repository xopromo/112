// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0
// © Mathematical Turning Points Indicator

//@version=5
indicator("Turning Points · 7 Mathematical Methods", overlay=true, max_bars_back=500)

// ══════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════
grpSig = "▸ Signal"
i_vote    = input.int(4,    "Min votes for signal (of 7)", 1, 7, group=grpSig,
     tooltip="How many methods must agree to produce a signal")
i_showLns = input.bool(true, "Show regression lines",       group=grpSig)

grpPrm = "▸ Method Parameters"
i_kLen = input.int(50,    "Kernel regression lookback",     5,  200, group=grpPrm)
i_kBw  = input.float(8.0, "Kernel bandwidth (h)",          0.5, 50.0, step=0.5, group=grpPrm,
     tooltip="Gaussian kernel: larger h = smoother estimate")
i_csL  = input.int(20,    "CUSUM window",                   5,  100, group=grpPrm)
i_kfQ  = input.float(0.01,"Kalman process noise Q",      1e-4,  1.0, step=0.001, group=grpPrm)
i_kfR  = input.float(0.1, "Kalman measurement noise R",  1e-3,  5.0, step=0.01,  group=grpPrm)
i_ssaL = input.int(20,    "SSA/LinReg window",               5,  100, group=grpPrm)
i_psLb = input.int(10,    "Persistence lookback bars",       3,   50, group=grpPrm)

src = close

// ══════════════════════════════════════════════════════════════════════════
// M1 — CURVATURE   κ = |f''| / (1 + f'²)^1.5
//   Turning point = local κ-maximum coinciding with sign reversal of f'
// ══════════════════════════════════════════════════════════════════════════
fp1  = (src - src[2]) / 2.0                     // central difference f'
fp2  = src - 2.0 * src[1] + src[2]              // second difference f''
kap  = math.abs(fp2) / math.pow(1.0 + fp1 * fp1, 1.5)
kpk  = kap > kap[1] and kap > kap[2] and kap > kap[3]  // local max of κ

m1 = kpk and fp1[1] < 0.0 and fp1 >= 0.0 ?  1   // curvature peak at trough
   : kpk and fp1[1] > 0.0 and fp1 <= 0.0 ? -1   // curvature peak at peak
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M2 — CUSUM change-point detection
//   Turning point = CUSUM statistic exceeds 2σ and begins declining
// ══════════════════════════════════════════════════════════════════════════
mu2  = ta.sma(src, i_csL)
sd2  = ta.stdev(src, i_csL)
k2   = sd2 * 0.5                                // slack parameter

var float csp = 0.0                              // upward CUSUM
var float csn = 0.0                              // downward CUSUM
csp := math.max(0.0, csp + (src - mu2 - k2))
csn := math.max(0.0, csn + (mu2 - k2 - src))
thr2 = sd2 * 2.0

m2 = csn > thr2 and csn < csn[1] ?  1           // downward CS peaked → long
   : csp > thr2 and csp < csp[1] ? -1           // upward CS peaked → short
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M3 — KALMAN FILTER: cumulative innovation sign reversal
//   Turning point = running sign-sum of prediction error changes direction
// ══════════════════════════════════════════════════════════════════════════
var float kx  = float(na)
var float kp  = 1.0
var float kcs = 0.0
float inn = 0.0

if na(kx)
    kx := src
else
    float kpp = kp + i_kfQ
    float kg  = kpp / (kpp + i_kfR)
    inn   := src - kx
    kx    := kx + kg * inn
    kp    := (1.0 - kg) * kpp

kcs := kcs + math.sign(inn)

m3 = kcs[1] < 0.0 and kcs >= 0.0 ?  1
   : kcs[1] > 0.0 and kcs <= 0.0 ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M4 — NADARAYA-WATSON KERNEL REGRESSION  (Gaussian kernel)
//   Turning point = zero-crossing of kernel estimate's first derivative m̂'
// ══════════════════════════════════════════════════════════════════════════
float nwn = 0.0
float nwd = 0.0
for j = 0 to i_kLen - 1
    float w = math.exp(-float(j * j) / (2.0 * i_kBw * i_kBw))
    nwn += w * src[j]
    nwd += w

nw_val = nwd > 0.0 ? nwn / nwd : src            // kernel estimate
nwsl   = nw_val - nw_val[1]                      // derivative via finite diff

m4 = nwsl[1] < 0.0 and nwsl >= 0.0 ?  1
   : nwsl[1] > 0.0 and nwsl <= 0.0 ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M5 — SSA TREND  (1st component ≈ linear regression on window L)
//   Turning point = linreg slope crosses zero  (trend inflection)
// ══════════════════════════════════════════════════════════════════════════
ssa   = ta.linreg(src, i_ssaL, 0)
ssasl = ssa - ssa[1]

m5 = ta.crossover(ssasl, 0.0)  ?  1
   : ta.crossunder(ssasl, 0.0) ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M6 — HILBERT TRANSFORM PHASE  (Ehlers discrete approximation)
//   Instantaneous frequency dφ/dt → zero-crossing = extremum of cycle
// ══════════════════════════════════════════════════════════════════════════
float sm6 = (src + 2.0*src[1] + 2.0*src[2] + src[3]) / 6.0   // 4-bar smooth

// Quadrature and In-Phase components (Ehlers FIR coefficients)
float q6  = 0.0962*sm6 + 0.5769*nz(sm6[2]) - 0.5769*nz(sm6[4]) - 0.0962*nz(sm6[6])
float i6  = nz(sm6[3])

// Phase with quadrant correction
float ph6_raw = i6 != 0.0 ? math.atan(math.abs(q6 / i6)) * 180.0 / math.pi : 0.0
float ph6     = i6 < 0.0                   ? 180.0 - ph6_raw
              : i6 >= 0.0 and q6 < 0.0    ? 360.0 - ph6_raw
              : ph6_raw

float dph6 = ph6 - ph6[1]                  // instantaneous frequency

m6 = ta.crossover(dph6, 0.0)  ?  1
   : ta.crossunder(dph6, 0.0) ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M7 — TOPOLOGICAL PERSISTENCE  (birth-death significance filter)
//   Turning point = local extremum whose persistence > 1.5 × ATR
//   Persistence = height difference to nearest higher neighbor
// ══════════════════════════════════════════════════════════════════════════
pthr = ta.atr(14) * 1.5

bool ipk = ta.highestbars(src, i_psLb) == 0 and
     (src - ta.lowest(src, i_psLb))  > pthr    // significant peak

bool itr = ta.lowestbars(src, i_psLb) == 0 and
     (ta.highest(src, i_psLb) - src) > pthr    // significant trough

m7 = itr ? 1 : ipk ? -1 : 0

// ══════════════════════════════════════════════════════════════════════════
// COMPOSITE VOTE AGGREGATION
// ══════════════════════════════════════════════════════════════════════════
ms = array.from(m1, m2, m3, m4, m5, m6, m7)
int vL = 0
int vS = 0
for i = 0 to 6
    int v = array.get(ms, i)
    vL += v ==  1 ? 1 : 0
    vS += v == -1 ? 1 : 0

bool sigL = vL >= i_vote
bool sigS = vS >= i_vote

bool entL = sigL and not sigL[1]
bool entS = sigS and not sigS[1]
bool exL  = sigL[1] and (not sigL or sigS)     // long exit: vote fell OR short appeared
bool exS  = sigS[1] and (not sigS or sigL)     // short exit: vote fell OR long appeared

// ══════════════════════════════════════════════════════════════════════════
// REGRESSION LINES
// ══════════════════════════════════════════════════════════════════════════
plot(i_showLns ? nw_val : na, "Kernel Regression",
     color.new(color.yellow, 10), 2)
plot(i_showLns ? kx     : na, "Kalman State",
     color.new(color.aqua, 40), 1)
plot(i_showLns ? ssa    : na, "SSA Trend",
     color.new(color.fuchsia, 40), 1)

// ══════════════════════════════════════════════════════════════════════════
// ENTRY / EXIT SIGNALS
// ══════════════════════════════════════════════════════════════════════════
plotshape(entL, "Long Entry",  shape.labelup,   location.belowbar,
     color.lime,              text="▲ LONG",  textcolor=color.black, size=size.normal)
plotshape(entS, "Short Entry", shape.labeldown, location.abovebar,
     color.red,               text="▼ SHORT", textcolor=color.white, size=size.normal)

plotshape(exL, "Long Exit",   shape.xcross, location.abovebar,
     color.new(color.orange, 0), size=size.small)
plotshape(exS, "Short Exit",  shape.xcross, location.belowbar,
     color.new(color.orange, 0), size=size.small)

// Background tint while position is open
bgcolor(sigL ? color.new(color.lime, 92) : na)
bgcolor(sigS ? color.new(color.red,  92) : na)

// ══════════════════════════════════════════════════════════════════════════
// VOTE TABLE  (top-right corner)
// ══════════════════════════════════════════════════════════════════════════
var table tbl = table.new(
     position.top_right, 3, 10,
     bgcolor       = color.new(color.black, 60),
     border_width  = 1,
     border_color  = color.new(color.gray, 60))

if barstate.islast
    // Header
    table.cell(tbl, 0, 0, "Method",
         text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, 0, "L " + str.tostring(vL),
         text_color=color.lime, text_size=size.tiny)
    table.cell(tbl, 2, 0, "S " + str.tostring(vS),
         text_color=color.red,  text_size=size.tiny)

    // Method rows
    string[] names = array.from("Curvature","CUSUM","Kalman","Kernel","SSA","Hilbert","Persist")
    for i = 0 to 6
        int    v  = array.get(ms, i)
        string nm = array.get(names, i)
        color  cl = color.new(color.gray, 40)
        table.cell(tbl, 0, i + 1, nm,
             text_color=color.silver, text_size=size.tiny, text_halign=text.align_left)
        table.cell(tbl, 1, i + 1, v ==  1 ? "✓" : "·",
             text_color=v ==  1 ? color.lime : cl, text_size=size.tiny)
        table.cell(tbl, 2, i + 1, v == -1 ? "✓" : "·",
             text_color=v == -1 ? color.red  : cl, text_size=size.tiny)

    // Score footer
    table.cell(tbl, 0, 8, "── score ──",
         text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, 8, str.tostring(vL) + "/" + str.tostring(i_vote),
         text_color=sigL ? color.lime : color.gray, text_size=size.tiny)
    table.cell(tbl, 2, 8, str.tostring(vS) + "/" + str.tostring(i_vote),
         text_color=sigS ? color.red  : color.gray, text_size=size.tiny)

    // Info row
    table.cell(tbl, 0, 9, "threshold: " + str.tostring(i_vote) + "/7",
         text_color=color.new(color.gray, 20), text_size=size.tiny,
         text_halign=text.align_left, bgcolor=color.new(color.black, 40))
    table.merge_cells(tbl, 0, 9, 2, 9)
