// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0
// © Mathematical Turning Points Indicator

//@version=5
indicator("Turning Points · 7 Mathematical Methods", overlay=true, max_bars_back=500)

// ══════════════════════════════════════════════════════════════════════════
// INPUTS — MODE
// ══════════════════════════════════════════════════════════════════════════
grpMode = "▸ Mode"
i_mode = input.string("Composite",
     "Active method",
     options=["Composite",
              "M1: Curvature",
              "M2: CUSUM",
              "M3: Kalman",
              "M4: Kernel Regression",
              "M5: SSA Trend",
              "M6: Hilbert Transform",
              "M7: Persistence"],
     group=grpMode,
     tooltip="'Composite' = vote of all enabled methods.\nAny other = test that single method in isolation.")

i_vote    = input.int(4, "Composite: min votes (of 7)", 1, 7, group=grpMode,
     tooltip="Only used in Composite mode")
i_showLns = input.bool(true, "Show regression lines", group=grpMode)

// ── Enable / disable individual methods in Composite mode ────────────────
grpEn = "▸ Enable in Composite"
i_en1 = input.bool(true, "M1  Curvature",        group=grpEn)
i_en2 = input.bool(true, "M2  CUSUM",             group=grpEn)
i_en3 = input.bool(true, "M3  Kalman",            group=grpEn)
i_en4 = input.bool(true, "M4  Kernel Regression", group=grpEn)
i_en5 = input.bool(true, "M5  SSA Trend",         group=grpEn)
i_en6 = input.bool(true, "M6  Hilbert Transform", group=grpEn)
i_en7 = input.bool(true, "M7  Persistence",       group=grpEn)

// ── Method parameters ─────────────────────────────────────────────────────
grpPrm = "▸ Method Parameters"
i_kLen = input.int(50,    "Kernel regression lookback",  5,  200, group=grpPrm)
i_kBw  = input.float(8.0, "Kernel bandwidth (h)",       0.5, 50.0, step=0.5, group=grpPrm,
     tooltip="Gaussian kernel: larger h = smoother estimate")
i_csL  = input.int(20,    "CUSUM window",                5,  100, group=grpPrm)
i_kfQ  = input.float(0.01,"Kalman process noise Q",   1e-4,  1.0, step=0.001, group=grpPrm)
i_kfR  = input.float(0.1, "Kalman measurement noise R",1e-3,  5.0, step=0.01,  group=grpPrm)
i_ssaL = input.int(20,    "SSA/LinReg window",           5,  100, group=grpPrm)
i_psLb = input.int(10,    "Persistence lookback bars",   3,   50, group=grpPrm)
i_pAtr = input.float(1.5, "Persistence ATR multiplier", 0.5,  5.0, step=0.1, group=grpPrm)

src = close

// ══════════════════════════════════════════════════════════════════════════
// M1 — CURVATURE   κ = |f''| / (1 + f'²)^1.5
// ══════════════════════════════════════════════════════════════════════════
fp1 = (src - src[2]) / 2.0
fp2 = src - 2.0 * src[1] + src[2]
kap = math.abs(fp2) / math.pow(1.0 + fp1 * fp1, 1.5)
kpk = kap > kap[1] and kap > kap[2] and kap > kap[3]

m1 = kpk and fp1[1] < 0.0 and fp1 >= 0.0 ?  1
   : kpk and fp1[1] > 0.0 and fp1 <= 0.0 ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M2 — CUSUM change-point detection
// ══════════════════════════════════════════════════════════════════════════
mu2 = ta.sma(src, i_csL)
sd2 = ta.stdev(src, i_csL)
k2  = sd2 * 0.5

var float csp = 0.0
var float csn = 0.0
csp := math.max(0.0, csp + (src - mu2 - k2))
csn := math.max(0.0, csn + (mu2 - k2 - src))
thr2 = sd2 * 2.0

m2 = csn > thr2 and csn < csn[1] ?  1
   : csp > thr2 and csp < csp[1] ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M3 — KALMAN FILTER: cumulative innovation sign reversal
// ══════════════════════════════════════════════════════════════════════════
var float kx  = float(na)
var float kp  = 1.0
var float kcs = 0.0
float inn = 0.0

if na(kx)
    kx := src
else
    float kpp = kp + i_kfQ
    float kg  = kpp / (kpp + i_kfR)
    inn   := src - kx
    kx    := kx + kg * inn
    kp    := (1.0 - kg) * kpp

kcs := kcs + math.sign(inn)

m3 = kcs[1] < 0.0 and kcs >= 0.0 ?  1
   : kcs[1] > 0.0 and kcs <= 0.0 ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M4 — NADARAYA-WATSON KERNEL REGRESSION  (Gaussian kernel)
// ══════════════════════════════════════════════════════════════════════════
float nwn = 0.0
float nwd = 0.0
for j = 0 to i_kLen - 1
    float w = math.exp(-float(j * j) / (2.0 * i_kBw * i_kBw))
    nwn += w * src[j]
    nwd += w

nw_val = nwd > 0.0 ? nwn / nwd : src
nwsl   = nw_val - nw_val[1]

m4 = nwsl[1] < 0.0 and nwsl >= 0.0 ?  1
   : nwsl[1] > 0.0 and nwsl <= 0.0 ? -1
   : 0

// ══════════════════════════════════════════════════════════════════════════
// M5 — SSA TREND  (1st component ≈ linear regression on window L)
// ══════════════════════════════════════════════════════════════════════════
ssa   = ta.linreg(src, i_ssaL, 0)
ssasl = ssa - ssa[1]

bool m5_co = ta.crossover(ssasl,  0.0)
bool m5_cu = ta.crossunder(ssasl, 0.0)
m5 = m5_co ?  1 : m5_cu ? -1 : 0

// ══════════════════════════════════════════════════════════════════════════
// M6 — HILBERT TRANSFORM PHASE  (Ehlers discrete approximation)
// ══════════════════════════════════════════════════════════════════════════
float sm6     = (src + 2.0*src[1] + 2.0*src[2] + src[3]) / 6.0
float q6      = 0.0962*sm6 + 0.5769*nz(sm6[2]) - 0.5769*nz(sm6[4]) - 0.0962*nz(sm6[6])
float i6      = nz(sm6[3])
float ph6_raw = i6 != 0.0 ? math.atan(math.abs(q6 / i6)) * 180.0 / math.pi : 0.0
float ph6     = i6 < 0.0                ? 180.0 - ph6_raw
              : i6 >= 0.0 and q6 < 0.0 ? 360.0 - ph6_raw
              : ph6_raw
float dph6    = ph6 - ph6[1]

bool m6_co = ta.crossover(dph6,  0.0)
bool m6_cu = ta.crossunder(dph6, 0.0)
m6 = m6_co ?  1 : m6_cu ? -1 : 0

// ══════════════════════════════════════════════════════════════════════════
// M7 — TOPOLOGICAL PERSISTENCE  (ATR-filtered significant extrema)
// ══════════════════════════════════════════════════════════════════════════
pthr  = ta.atr(14) * i_pAtr
bool ipk = ta.highestbars(src, i_psLb) == 0 and (src - ta.lowest(src,  i_psLb)) > pthr
bool itr = ta.lowestbars(src,  i_psLb) == 0 and (ta.highest(src, i_psLb) - src) > pthr

m7 = itr ? 1 : ipk ? -1 : 0

// ══════════════════════════════════════════════════════════════════════════
// SIGNAL SELECTION: solo mode OR composite vote
// ══════════════════════════════════════════════════════════════════════════
// Count enabled methods for dynamic max votes
int nEnabled = (i_en1?1:0)+(i_en2?1:0)+(i_en3?1:0)+(i_en4?1:0)+
               (i_en5?1:0)+(i_en6?1:0)+(i_en7?1:0)

bool sigL = false
bool sigS = false
int  vL   = 0
int  vS   = 0
int  activeM = 0   // vote of active single method (for table)

if i_mode == "Composite"
    vL := (i_en1 and m1==1?1:0)+(i_en2 and m2==1?1:0)+(i_en3 and m3==1?1:0)+
          (i_en4 and m4==1?1:0)+(i_en5 and m5==1?1:0)+(i_en6 and m6==1?1:0)+
          (i_en7 and m7==1?1:0)
    vS := (i_en1 and m1==-1?1:0)+(i_en2 and m2==-1?1:0)+(i_en3 and m3==-1?1:0)+
          (i_en4 and m4==-1?1:0)+(i_en5 and m5==-1?1:0)+(i_en6 and m6==-1?1:0)+
          (i_en7 and m7==-1?1:0)
    sigL := vL >= i_vote
    sigS := vS >= i_vote
else
    activeM := i_mode == "M1: Curvature"          ? m1
             : i_mode == "M2: CUSUM"              ? m2
             : i_mode == "M3: Kalman"             ? m3
             : i_mode == "M4: Kernel Regression"  ? m4
             : i_mode == "M5: SSA Trend"          ? m5
             : i_mode == "M6: Hilbert Transform"  ? m6
             : i_mode == "M7: Persistence"        ? m7
             : 0
    sigL := activeM ==  1
    sigS := activeM == -1

bool entL = sigL and not sigL[1]
bool entS = sigS and not sigS[1]
bool exL  = sigL[1] and (not sigL or sigS)
bool exS  = sigS[1] and (not sigS or sigL)

// ══════════════════════════════════════════════════════════════════════════
// REGRESSION LINES
// ══════════════════════════════════════════════════════════════════════════
bool showKernel = i_showLns and (i_mode == "Composite" or i_mode == "M4: Kernel Regression")
bool showKalman = i_showLns and (i_mode == "Composite" or i_mode == "M3: Kalman")
bool showSSA    = i_showLns and (i_mode == "Composite" or i_mode == "M5: SSA Trend")

plot(showKernel ? nw_val : na, "Kernel Regression", color.new(color.yellow,  10), 2)
plot(showKalman ? kx     : na, "Kalman State",      color.new(color.aqua,    40), 1)
plot(showSSA    ? ssa    : na, "SSA Trend",         color.new(color.fuchsia, 40), 1)

// ══════════════════════════════════════════════════════════════════════════
// ENTRY / EXIT SIGNALS
// ══════════════════════════════════════════════════════════════════════════
// plotshape requires const string for text — split into two calls per direction
bool isComposite = i_mode == "Composite"
plotshape(entL and isComposite,  "Long Entry",       shape.labelup,   location.belowbar,
     color.lime, text="▲ LONG",  textcolor=color.black, size=size.normal)
plotshape(entL and not isComposite, "Long Entry Solo",  shape.labelup,   location.belowbar,
     color.lime, text="▲",       textcolor=color.black, size=size.normal)
plotshape(entS and isComposite,  "Short Entry",      shape.labeldown, location.abovebar,
     color.red,  text="▼ SHORT", textcolor=color.white, size=size.normal)
plotshape(entS and not isComposite, "Short Entry Solo", shape.labeldown, location.abovebar,
     color.red,  text="▼",       textcolor=color.white, size=size.normal)

plotshape(exL, "Long Exit",  shape.xcross, location.abovebar,
     color.new(color.orange, 0), size=size.small)
plotshape(exS, "Short Exit", shape.xcross, location.belowbar,
     color.new(color.orange, 0), size=size.small)

bgcolor(sigL ? color.new(color.lime, 92) : na)
bgcolor(sigS ? color.new(color.red,  92) : na)

// ══════════════════════════════════════════════════════════════════════════
// TABLE
// ══════════════════════════════════════════════════════════════════════════
var table tbl = table.new(
     position.top_right, 4, 11,
     bgcolor      = color.new(color.black, 60),
     border_width = 1,
     border_color = color.new(color.gray, 60))

if barstate.islast
    // Header row
    table.cell(tbl, 0, 0, "Method",
         text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tbl, 1, 0, "on",
         text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 2, 0, "L",
         text_color=color.lime, text_size=size.tiny)
    table.cell(tbl, 3, 0, "S",
         text_color=color.red,  text_size=size.tiny)

    // Per-method rows
    string[] names = array.from(
         "Curvature", "CUSUM", "Kalman",
         "Kernel", "SSA", "Hilbert", "Persist")
    bool[] ens = array.from(i_en1, i_en2, i_en3, i_en4, i_en5, i_en6, i_en7)
    int[]  mvs = array.from(m1, m2, m3, m4, m5, m6, m7)

    for i = 0 to 6
        int    v   = array.get(mvs, i)
        bool   en  = array.get(ens, i)
        string nm  = array.get(names, i)

        // Highlight row if this is the active solo method
        bool isSolo = not (i_mode == "Composite") and
             ((i == 0 and i_mode == "M1: Curvature")         or
              (i == 1 and i_mode == "M2: CUSUM")             or
              (i == 2 and i_mode == "M3: Kalman")            or
              (i == 3 and i_mode == "M4: Kernel Regression") or
              (i == 4 and i_mode == "M5: SSA Trend")         or
              (i == 5 and i_mode == "M6: Hilbert Transform") or
              (i == 6 and i_mode == "M7: Persistence"))

        color rowBg = isSolo ? color.new(color.blue, 60) : color.new(color.black, 70)
        color nmClr = isSolo ? color.white
                     : en    ? color.silver
                     :         color.new(color.gray, 50)

        table.cell(tbl, 0, i + 1, (isSolo ? "► " : "  ") + nm,
             text_color=nmClr,     text_size=size.tiny,
             text_halign=text.align_left, bgcolor=rowBg)
        table.cell(tbl, 1, i + 1, en ? "✓" : "·",
             text_color=en ? color.new(color.gray, 0) : color.new(color.gray, 60),
             text_size=size.tiny, bgcolor=rowBg)
        table.cell(tbl, 2, i + 1, v ==  1 ? "▲" : "·",
             text_color=v ==  1 ? color.lime : color.new(color.gray, 50),
             text_size=size.tiny, bgcolor=rowBg)
        table.cell(tbl, 3, i + 1, v == -1 ? "▼" : "·",
             text_color=v == -1 ? color.red  : color.new(color.gray, 50),
             text_size=size.tiny, bgcolor=rowBg)

    // Footer: composite score
    table.cell(tbl, 0, 8, "─────────",
         text_color=color.new(color.gray, 50), text_size=size.tiny,
         text_halign=text.align_left)
    table.merge_cells(tbl, 0, 8, 3, 8)

    string scoreStr = i_mode == "Composite"
         ? "L " + str.tostring(vL) + "  S " + str.tostring(vS) +
           "  thr " + str.tostring(i_vote) + "/" + str.tostring(nEnabled)
         : "Solo: " + i_mode
    color  scoreClr = sigL ? color.lime : sigS ? color.red : color.gray

    table.cell(tbl, 0, 9, scoreStr,
         text_color=scoreClr, text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(tbl, 0, 9, 3, 9)

    // Signal state
    string stateStr = sigL ? "▲ LONG active"
                   : sigS ? "▼ SHORT active"
                   :        "— no signal"
    color  stateBg  = sigL ? color.new(color.lime, 70)
                   : sigS ? color.new(color.red,  70)
                   :        color.new(color.black, 50)

    table.cell(tbl, 0, 10, stateStr,
         text_color=color.white, text_size=size.tiny,
         text_halign=text.align_center, bgcolor=stateBg)
    table.merge_cells(tbl, 0, 10, 3, 10)
